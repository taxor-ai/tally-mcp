# Integration Test Configuration
# Copy this file to .env.test and update with your Tally connection details

# Tally server connection
TALLY_HOST=localhost
TALLY_PORT=9900
TALLY_COMPANY=Your Company Name

# Logging (optional, defaults to 'info')
# Options: debug, info, warn, error
TALLY_LOG_LEVEL=info

# Optional: log file path (if not specified, logs to stdout)
# TALLY_LOG_FILE=tally-mcp.log
