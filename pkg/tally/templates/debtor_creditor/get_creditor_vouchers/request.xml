<ENVELOPE>
    <HEADER>
        <VERSION>1</VERSION>
        <TALLYREQUEST>Export</TALLYREQUEST>
        <TYPE>Collection</TYPE>
        <ID>CreditorVouchers</ID>
    </HEADER>
    <BODY>
        <DESC>
            <STATICVARIABLES>
                <SVEXPORTFORMAT>$$SysName:XML</SVEXPORTFORMAT>
                <SVCURRENTCOMPANY>{{ company_name | e }}</SVCURRENTCOMPANY>
                <SVFROMDATE>{{ start_date }}</SVFROMDATE>
                <SVTODATE>{{ end_date }}</SVTODATE>
            </STATICVARIABLES>
            <TDL>
                <TDLMESSAGE>
                    <COLLECTION NAME="CreditorVouchers">
                        <TYPE>Voucher</TYPE>
                        <FETCH>DATE, VOUCHERNUMBER, REFERENCE, NARRATION, VOUCHERTYPENAME, ALLLEDGERENTRIES</FETCH>
                        <FILTER>HasCreditor</FILTER>
                    </COLLECTION>
                    <SYSTEM TYPE="Formulae" NAME="HasCreditor">$PARTYLEDGERNAME = "{{ creditor_ledger_name | e }}"</SYSTEM>
                </TDLMESSAGE>
            </TDL>
        </DESC>
    </BODY>
</ENVELOPE>
