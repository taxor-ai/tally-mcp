<ENVELOPE>
    <HEADER>
        <VERSION>1</VERSION>
        <TALLYREQUEST>Export</TALLYREQUEST>
        <TYPE>Collection</TYPE>
        <ID>DebtorReceipts</ID>
    </HEADER>
    <BODY>
        <DESC>
            <STATICVARIABLES>
                <SVEXPORTFORMAT>$$SysName:XML</SVEXPORTFORMAT>
                <SVCURRENTCOMPANY>{{ company_name | e }}</SVCURRENTCOMPANY>
            </STATICVARIABLES>
            <TDL>
                <TDLMESSAGE>
                    <COLLECTION NAME="DebtorReceipts">
                        <TYPE>Voucher</TYPE>
                        <FETCH>DATE, VOUCHERNUMBER, REFERENCE, NARRATION, VOUCHERTYPENAME, ALLLEDGERENTRIES</FETCH>
                        <FILTER>IsDebtorReceiptVoucher</FILTER>
                    </COLLECTION>
                    <SYSTEM TYPE="Formula" NAME="IsDebtorReceiptVoucher">$VOUCHERTYPENAME = "Receipt" AND NOT $$IsEmpty:$$FilterValue:$LEDGERNAME:ALLLEDGERENTRIES:FIRST:MatchDebtorLedger</SYSTEM>
                    <SYSTEM TYPE="Formula" NAME="MatchDebtorLedger">$LEDGERNAME = "{{ party_ledger_name | e }}"</SYSTEM>
                </TDLMESSAGE>
            </TDL>
        </DESC>
    </BODY>
</ENVELOPE>
